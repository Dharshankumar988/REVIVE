# Backend API URL used by browser fetch calls
NEXT_PUBLIC_API_URL=http://localhost:8080

# Backend websocket URL used by the dashboard
# For Android emulator use: ws://10.0.2.2:8080/ws/vitals
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/vitals

# Supabase project URL and public anon key (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
